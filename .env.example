# Copy this file to `.env.local` and fill in the values for local development.
# `.env.local` is gitignored — never commit real secrets / projectIds.
#
# Vercel deploys read these from the dashboard:
#   Settings → Environment Variables (Production / Preview / Development).

# WalletConnect Cloud projectId — required for WalletConnect-based wallets
# (Rainbow, Trust, mobile). MetaMask / injected wallets work without it.
# In production the app throws at boot if this is missing.
# Get a free projectId at https://cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Site origin used by the share modal (A4) to compose absolute lesson URLs
# in the prefilled tweet. Locally use http://localhost:3000.
NEXT_PUBLIC_SITE_ORIGIN=https://academia.idrop.so
